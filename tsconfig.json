{
  "compilerOptions": {
    "target": "ES2016",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "static/js",
    "rootDir": "src/scripts",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "ES2016"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/scripts/**/*.ts"]
}
